#!/usr/bin/env bash
set -euo pipefail

VERSION="0.3.1-dev"

usage() {
  cat <<'USAGE'
Ship Mode - preview-only desktop mode planner for SableOS

Usage:
  ship-mode help
  ship-mode list
  ship-mode current
  ship-mode preview work
  ship-mode preview lounge
  ship-mode preview clean
  ship-mode preview engineering

Commands:
  help                 Show this help message
  list                 List planned Ship Modes
  current              Show current placeholder mode state
  preview <mode>       Preview what a mode would do without changing anything

Important:
  This command is preview-only.
  It does not change wallpapers, widgets, startup apps, Cinnamon settings, panels, windows, displays, or running processes.
USAGE
}

list_modes() {
  cat <<'MODES'
Available Ship Modes:

  work
    Focused productivity mode for deep work, planning, writing, communication, and task management.

  lounge
    Relaxed mode for media, browsing, ambient use, personal time, and low-pressure creative work.

  clean
    Minimal reset mode designed to reduce visual clutter and return the desktop to a quiet baseline.

  engineering
    Technical mode for development, diagnostics, system tools, local services, logs, and build workflows.
MODES
}

current_mode() {
  cat <<'CURRENT'
Current Ship Mode:

  unknown

Reason:
  Ship Mode is currently preview-only.
  No live desktop state tracking has been implemented yet.

Nothing has been changed.
CURRENT
}

preview_work() {
  cat <<'PREVIEW'
Ship Mode Preview: work

This mode would eventually prepare the desktop for focused productivity.

Future possible actions:

  - Reduce distractions
  - Prioritize active tasks and planning tools
  - Surface useful communication or calendar context
  - Organize windows for focused work
  - Hide nonessential visual noise

Preview result:

  No desktop changes were made.
PREVIEW
}

preview_lounge() {
  cat <<'PREVIEW'
Ship Mode Preview: lounge

This mode would eventually prepare the desktop for relaxed, low-pressure use.

Future possible actions:

  - Use warmer or calmer visuals
  - Prioritize media, browsing, or ambient tools
  - Surface personal or creative widgets
  - Reduce work-focused reminders
  - Support casual desktop layouts

Preview result:

  No desktop changes were made.
PREVIEW
}

preview_clean() {
  cat <<'PREVIEW'
Ship Mode Preview: clean

This mode would eventually reset the desktop into a quiet, minimal baseline.

Future possible actions:

  - Hide nonessential overlays
  - Stop optional widgets
  - Reduce visual clutter
  - Keep only core launchers and system status
  - Act as a safe fallback mode

Preview result:

  No desktop changes were made.
PREVIEW
}

preview_engineering() {
  cat <<'PREVIEW'
Ship Mode Preview: engineering

This mode would eventually prepare the desktop for technical work and system building.

Future possible actions:

  - Prioritize terminal and development tools
  - Surface diagnostics and system health
  - Show logs or local service status
  - Open project folders or build contexts
  - Prepare the desktop for troubleshooting or development workflows

Preview result:

  No desktop changes were made.
PREVIEW
}

preview_mode() {
  local mode="${1:-}"

  case "$mode" in
    work)
      preview_work
      ;;
    lounge)
      preview_lounge
      ;;
    clean)
      preview_clean
      ;;
    engineering)
      preview_engineering
      ;;
    "")
      echo "ERROR: Missing mode name."
      echo
      echo "Try:"
      echo "  ship-mode preview work"
      echo "  ship-mode preview lounge"
      echo "  ship-mode preview clean"
      echo "  ship-mode preview engineering"
      exit 1
      ;;
    *)
      echo "ERROR: Unknown Ship Mode: $mode"
      echo
      list_modes
      exit 1
      ;;
  esac
}

COMMAND="${1:-help}"

case "$COMMAND" in
  help|--help|-h)
    usage
    ;;

  list)
    list_modes
    ;;

  current)
    current_mode
    ;;

  preview)
    shift || true
    preview_mode "${1:-}"
    ;;

  version)
    echo "$VERSION"
    ;;

  *)
    echo "Unknown ship-mode command: $COMMAND"
    echo "Run: ship-mode help"
    exit 1
    ;;
esac
