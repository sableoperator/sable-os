#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

find_sableos_root() {
  local candidate
  local candidates=(
    "$SCRIPT_DIR/../../.."
    "$(pwd)"
    "$HOME/Projects/sable-os"
  )

  if [[ -n "${SABLEOS_ROOT:-}" && -d "$SABLEOS_ROOT" ]]; then
    echo "$SABLEOS_ROOT"
    return 0
  fi

  for candidate in "${candidates[@]}"; do
    candidate="$(cd "$candidate" 2>/dev/null && pwd || true)"

    if [[ -n "$candidate" && -f "$candidate/install.sh" && -d "$candidate/modules" ]]; then
      echo "$candidate"
      return 0
    fi
  done

  echo ""
  return 1
}

SABLEOS_ROOT_DIR="$(find_sableos_root || true)"

usage() {
  cat <<'USAGE'
Sable CLI - main command hub for SableOS

Usage:
  sableos help
  sableos version
  sableos modules
  sableos doctor
  sableos status
  sableos mode list
  sableos mode current
  sableos mode preview work
  sableos mode preview lounge
  sableos mode preview clean
  sableos mode preview engineering
  sableos install list
  sableos install ship-doctor [options]
  sableos install sable-cli [options]
  sableos docs

Commands:
  help                              Show this help message
  version                           Print the current SableOS version
  modules                           List available modules
  doctor                            Run Ship Doctor diagnostics
  status                            Alias for doctor
  mode list                         List planned Ship Modes
  mode current                      Show current placeholder mode state
  mode preview <mode>               Preview a Ship Mode without changing anything
  install list                      List installable modules through the root installer
  install ship-doctor [options]     Install Ship Doctor through the root installer
  install sable-cli [options]       Install Sable CLI through the root installer
  docs                              Show local and GitHub documentation paths

Ship Mode preview options:
  work
  lounge
  clean
  engineering

Options are passed through to module installers where supported, including:
  --dry-run                         Show planned actions without changing anything
  --yes                             Run without interactive confirmation

Important:
  Ship Mode is preview-only right now.
  It does not change wallpapers, widgets, startup apps, Cinnamon settings, panels, windows, displays, or running processes.
USAGE
}

require_root() {
  if [[ -z "$SABLEOS_ROOT_DIR" ]]; then
    echo "ERROR: Could not locate the SableOS repository."
    echo
    echo "Try running from inside the repo:"
    echo "  cd ~/Projects/sable-os"
    echo
    echo "Or set:"
    echo '  export SABLEOS_ROOT="$HOME/Projects/sable-os"'
    exit 1
  fi
}

run_doctor() {
  if command -v ship-doctor >/dev/null 2>&1; then
    ship-doctor
    return
  fi

  require_root

  local repo_doctor="$SABLEOS_ROOT_DIR/modules/ship-doctor/bin/ship-doctor"

  if [[ -x "$repo_doctor" ]]; then
    "$repo_doctor"
  else
    echo "ERROR: Ship Doctor was not found."
    echo "Expected:"
    echo "  $repo_doctor"
    exit 1
  fi
}

run_mode() {
  require_root

  local repo_ship_mode="$SABLEOS_ROOT_DIR/modules/ship-mode/bin/ship-mode"

  if [[ -x "$repo_ship_mode" ]]; then
    "$repo_ship_mode" "$@"
  else
    echo "ERROR: Preview-only Ship Mode was not found."
    echo "Expected:"
    echo "  $repo_ship_mode"
    echo
    echo "SableOS Ship Mode should use the repo preview module, not any existing system ship-mode command."
    exit 1
  fi
}

show_version() {
  if [[ -n "$SABLEOS_ROOT_DIR" && -f "$SABLEOS_ROOT_DIR/VERSION" ]]; then
    cat "$SABLEOS_ROOT_DIR/VERSION"
  else
    echo "SableOS version unknown"
  fi
}

show_modules() {
  echo "Available SableOS modules:"
  echo "  ship-doctor"
  echo "  sable-cli"
  echo "  ship-mode"
}

show_docs() {
  if [[ -n "$SABLEOS_ROOT_DIR" ]]; then
    echo "Local docs:"
    echo "  $SABLEOS_ROOT_DIR/docs"
    echo
    echo "Documentation index:"
    echo "  $SABLEOS_ROOT_DIR/docs/README.md"
    echo
    echo "Ship Mode plan:"
    echo "  $SABLEOS_ROOT_DIR/docs/SHIP_MODE.md"
    echo
  else
    echo "Local docs:"
    echo "  SableOS repository not found"
    echo
  fi

  echo "GitHub docs:"
  echo "  https://github.com/sableoperator/sable-os/tree/main/docs"
}

run_install() {
  require_root

  local root_installer="$SABLEOS_ROOT_DIR/install.sh"

  if [[ ! -x "$root_installer" ]]; then
    echo "ERROR: Root installer not found or not executable:"
    echo "  $root_installer"
    exit 1
  fi

  "$root_installer" "$@"
}

COMMAND="${1:-help}"

case "$COMMAND" in
  help|--help|-h)
    usage
    ;;

  version)
    show_version
    ;;

  modules)
    show_modules
    ;;

  doctor)
    run_doctor
    ;;

  status)
    run_doctor
    ;;

  mode)
    shift || true

    if [[ $# -lt 1 ]]; then
      echo "ERROR: Missing mode command."
      echo
      echo "Try:"
      echo "  sableos mode list"
      echo "  sableos mode current"
      echo "  sableos mode preview work"
      exit 1
    fi

    run_mode "$@"
    ;;

  docs)
    show_docs
    ;;

  install)
    shift || true

    if [[ $# -lt 1 ]]; then
      echo "ERROR: Missing install command."
      echo
      usage
      exit 1
    fi

    run_install "$@"
    ;;

  *)
    echo "Unknown sableos command: $COMMAND"
    echo "Run: sableos help"
    exit 1
    ;;
esac
